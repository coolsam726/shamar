# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=zKXHe-Ahdb7aPK1ylAJlRgTefktEaACi
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# MongoDB (Shamar admin + auth — start with `pnpm docker:up` from repo root)
MONGO_URI=mongodb://127.0.0.1:27017/shamar_playground

# Auth login mode: local | ldap | both (LDAP first, then local fallback)
# Default: local when LDAP_DOMAINS is empty; both when domains are configured.
# Optional login page copy (overrides mode-based defaults; omit footer to hide it)
# AUTH_LOGIN_SUBTITLE=Sign in with your Strathmore account.
# AUTH_LOGIN_FOOTER=Need help? Contact ICT Support.
# AUTH_LOGIN_USERNAME_LABEL=Staff username
# AUTH_LOGIN_USERNAME_PLACEHOLDER=jdoe or jdoe@strathmore.edu
AUTH_LOGIN_MODE=local

# Dev only — shared password logs in as any existing local user (by email/username).
# Ignored when NODE_ENV=production even if set.
# MASQUERADE_PASSWORD=dev-masquerade-secret

# LDAP local-user linking after a successful directory bind:
#   existing (default) — user must already exist locally with externalId sync UID
#   create — auto-provision / upsert local users on first LDAP login
LDAP_PROVISIONING=existing

# Comma-separated LDAP domain ids. For each id PREFIX=LDAP_<ID>_…
# Example for id "corp":
#   LDAP_DOMAINS=corp
#   LDAP_CORP_URL=ldaps://dc.corp.example
#   LDAP_CORP_BIND_DN=cn=svc,dc=corp,dc=example
#   LDAP_CORP_BIND_PASSWORD=secret
#   LDAP_CORP_SEARCH_BASE=dc=corp,dc=example
#   LDAP_CORP_SEARCH_FILTER=(uid={{username}})
#   LDAP_CORP_EMAIL_DOMAINS=corp.example
#   LDAP_CORP_NETBIOS=CORP
#   LDAP_CORP_TIMEOUT=5              # seconds → operation + connect timeout (default 10s)
#   LDAP_CORP_CONNECT_TIMEOUT=3      # optional connect-only override (seconds)
LDAP_DOMAINS=

{
  "name": "@shamar/core",
  "version": "0.1.3",
  "description": "Filament-inspired resource DSL for Shamar admin (ORM-agnostic core).",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/coolsam726/shamar.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.js",

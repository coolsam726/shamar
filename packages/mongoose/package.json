{
  "name": "@shamar/mongoose",
  "version": "0.1.1",
  "description": "Mongoose DataAdapter for Shamar admin — list, CRUD, soft-delete, MongoDB models.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@shamar/core": "workspace:*"
  },
  "peerDependencies": {
    "mongoose": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "mongoose": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": { "access": "public" }
}

{
  "name": "@shamar/adonis",
  "version": "0.1.1",
  "description": "AdonisJS service provider for Shamar admin — routes, controllers, middleware, Edge views.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/coolsam726/shamar.git",
    "directory": "packages/adonis"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js"
    },
    "./require_api_key_middleware": {
      "types": "./dist/middleware/require_api_key_middleware.d.ts",
      "import": "./dist/middleware/require_api_key_middleware.js"
    }
  },
  "files": [
    "dist",
    "resources",
    "assets",
    "stubs"
  ],
  "scripts": {
    "build": "tsc",
    "build:css": "pnpm dlx @tailwindcss/cli@4.3.2 -i ./assets/input.css -o ./assets/admin.css --minify",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "pnpm build && pnpm build:css"
  },
  "dependencies": {
    "@shamar/cherubim": "workspace:*",
    "@shamar/core": "workspace:*",
    "@shamar/lucid": "workspace:*",
    "@shamar/mongoose": "workspace:*"
  },
  "peerDependencies": {
    "@adonisjs/core": ">=6.0.0",
    "@adonisjs/lucid": ">=21.0.0",
    "edge.js": ">=6.0.0",
    "mongoose": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "edge.js": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    },
    "@adonisjs/lucid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonisjs/core": "^7.3.5",
    "edge.js": "^6.5.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
